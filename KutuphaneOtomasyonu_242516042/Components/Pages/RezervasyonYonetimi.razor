@page "/rezervasyonlar"
@using KutuphaneOtomasyonu_242516042.Models
@using KutuphaneOtomasyonu_242516042.Data
@inject KutuphaneServisi KutuphaneServisi
@inject IJSRuntime JSRuntime
<PageTitle>Rezervasyon Yönetimi</PageTitle>

<h3>Rezervasyon Yönetimi</h3>

@if (!string.IsNullOrEmpty(_hataMesaji))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Hata Oluştu:</strong> @_hataMesaji
        <button type="button" class="btn-close" @onclick="HataKapat" aria-label="Close"></button>
    </div>
}

<div class="alert alert-info"><strong>Bilgi:</strong> Sadece şu an başkasında olan ('Ödünç Verildi' durumundaki) kitaplara rezervasyon yapılabilir.</div>

<EditForm Model="_yeniRezervasyonModeli" OnValidSubmit="HandleRezervasyonYap" FormName="RezervasyonFormu">
    <DataAnnotationsValidator />
    <div class="card shadow mb-4">
        <div class="card-header">Yeni Rezervasyon Yap</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <label>Üye Seçin:</label>
                    <InputSelect class="form-select" @bind-Value="_yeniRezervasyonModeli.UyeId">
                        <option value="0">-- Üye Seçin --</option>
                        @if (_uyeListesi != null)
                        {
                            @foreach (var uye in _uyeListesi)
                            {
                                <option value="@uye.Id">@uye.TamAd</option>
                            }
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6">
                    <label>Kitap Seçin:</label>
                    <InputSelect class="form-select" @bind-Value="_yeniRezervasyonModeli.KitapId">
                        <option value="0">-- Kitap Seçin --</option>
                        @if (_tumKitapListesi != null)
                        {
                            @foreach (var kitap in _tumKitapListesi)
                            {
                                <option value="@kitap.Id" disabled="@(kitap.Durum != "Odunc Verildi")">
                                    @kitap.Ad (@kitap.Durum)
                                </option>
                            }
                        }
                    </InputSelect>
                    <small class="text-muted">* Listede sadece ödünçteki kitaplar seçilebilir.</small>
                </div>
            </div>
        </div>
        <div class="card-footer"><button type="submit" class="btn btn-primary">Rezervasyon Yap</button></div>
    </div>
</EditForm>
<hr />

<h5>Aktif Rezervasyonlar</h5>
@if (_aktifRezervasyonListesi == null)
{
    <p><em>Yükleniyor...</em></p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Üye</th>
                <th>Kitap</th>
                <th>Rezervasyon Tarihi</th>
                <th>Durum</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rez in _aktifRezervasyonListesi)
            {
                <tr style="@(rez.Durum == "Hazır" ? "background-color: #d1e7dd;" : "")">
                    <td>@rez.UyeTamAdi</td>
                    <td>@rez.KitapAdi</td>
                    <td>@rez.RezervasyonTarihi.ToShortDateString()</td>
                    <td>@rez.Durum</td>
                    <td>
                        <button class="btn btn-sm btn-danger" @onclick="() => HandleIptal(rez.Id)">İptal Et</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Rezervasyon _yeniRezervasyonModeli = new();
    private List<Uye>? _uyeListesi;
    private List<Kitap>? _tumKitapListesi;
    private List<Rezervasyon>? _aktifRezervasyonListesi;
    private string? _hataMesaji;

    protected override async Task OnInitializedAsync()
    {
        await VerileriGetir();
    }

    private async Task VerileriGetir()
    {
        _hataMesaji = null;
        try
        {
            var uyeTask = KutuphaneServisi.UyeListeleAsync();
            var kitapTask = KutuphaneServisi.KitapListeleAsync();
            var rezervasyonTask = KutuphaneServisi.GetAktifRezervasyonlarAsync();

            await Task.WhenAll(uyeTask, kitapTask, rezervasyonTask);

            _uyeListesi = await uyeTask;
            _tumKitapListesi = await kitapTask;
            _aktifRezervasyonListesi = await rezervasyonTask;
        }
        catch (Exception ex)
        {
            _hataMesaji = "Veriler yüklenirken hata oluştu: " + ex.Message;
        }
    }

    private void HataKapat() { _hataMesaji = null; }

    private async Task HandleRezervasyonYap()
    {
        try
        {
            if (_yeniRezervasyonModeli.UyeId == 0 || _yeniRezervasyonModeli.KitapId == 0)
            {
                _hataMesaji = "Lütfen üye ve kitap seçiniz.";
                return;
            }

            await KutuphaneServisi.RezervasyonYapAsync(_yeniRezervasyonModeli.UyeId, _yeniRezervasyonModeli.KitapId);
            await JSRuntime.InvokeVoidAsync("alert", "Rezervasyon başarıyla oluşturuldu.");

            _yeniRezervasyonModeli = new();
            await VerileriGetir();
        }
        catch (Exception ex)
        {
            _hataMesaji = "İşlem hatası: " + ex.Message;
        }
    }

    private async Task HandleIptal(int rezervasyonId)
    {
        try
        {
            bool onay = await JSRuntime.InvokeAsync<bool>("confirm", "Bu rezervasyonu iptal etmek istediğinize emin misiniz?");
            if (onay)
            {
                await KutuphaneServisi.RezervasyonIptalAsync(rezervasyonId);
                await VerileriGetir();
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "İptal sırasında hata: " + ex.Message;
        }
    }
}