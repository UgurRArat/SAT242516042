@page "/uyeler"
@using KutuphaneOtomasyonu_242516042.Models
@using KutuphaneOtomasyonu_242516042.Data
@inject KutuphaneServisi KutuphaneServisi
@inject IJSRuntime JSRuntime
<PageTitle>Üye Yönetimi</PageTitle>

<h3>Üye Yönetimi</h3>
<EditForm Model="_model" OnValidSubmit="OnKaydet">
    <DataAnnotationsValidator />
    <div class="card shadow">
        <div class="card-header">@(_model.Id == 0 ? "Yeni Üye Ekle" : "Üye Düzenle")</div>
        <div class="card-body">
            <input type="hidden" @bind-value="_model.Id" />
            <div class="mb-3 row"><label class="col-sm-3 col-form-label">Ad</label><div class="col-sm-9">
                <InputText class="form-control" @bind-Value="_model.Ad" /><ValidationMessage For="@(() => _model.Ad)" /></div></div>
            <div class="mb-3 row"><label class="col-sm-3 col-form-label">Soyad</label><div class="col-sm-9">
                <InputText class="form-control" @bind-Value="_model.Soyad" /><ValidationMessage For="@(() => _model.Soyad)" /></div></div>
            <div class="mb-3 row"><label class="col-sm-3 col-form-label">Email</label><div class="col-sm-9">
                <InputText class="form-control" @bind-Value="_model.Email" /><ValidationMessage For="@(() => _model.Email)" /></div></div>
             <div class="mb-3 row"><label class="col-sm-3 col-form-label">TC Kimlik</label><div class="col-sm-9">
                <InputText class="form-control" @bind-Value="_model.TCKimlik" /><ValidationMessage For="@(() => _model.TCKimlik)" /></div></div>
            <div class="mb-3 row"><label class="col-sm-3 col-form-label">Telefon</label><div class="col-sm-9">
                <InputText class="form-control" @bind-Value="_model.Telefon" /></div></div>
            <div class="mb-3 row"><label class="col-sm-3 col-form-label">Adres</label><div class="col-sm-9">
                <InputTextArea class="form-control" @bind-Value="_model.Adres" /></div></div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">@(_model.Id == 0 ? "Ekle" : "Güncelle")</button>
            <button type="button" class="btn btn-secondary" @onclick="OnYeni">Yeni</button>
        </div>
    </div>
</EditForm>
<hr />
<h5>Kayıtlı Üyeler</h5>
@if (_uyeListesi == null) { <p><em>Üyeler yükleniyor...</em></p> }
else {
    <table class="table table-striped table-hover">
        <thead class="table-dark"><tr><th>Ad Soyad</th><th>Email</th><th>Telefon</th><th>TC Kimlik</th><th>İşlemler</th></tr></thead>
        <tbody>
            @foreach (var uye in _uyeListesi) {
                <tr>
                    <td>@uye.TamAd</td><td>@uye.Email</td><td>@uye.Telefon</td><td>@uye.TCKimlik</td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="() => OnDuzenle(uye)">Düzenle</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => OnSil(uye.Id)">Sil</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Uye>? _uyeListesi;
    private Uye _model = new();
    private string _operation = "add";

    protected override async Task OnInitializedAsync() { await VerileriGetir(); }
    private async Task VerileriGetir() {
        try { _uyeListesi = await KutuphaneServisi.UyeListeleAsync(); } 
        catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", "Üye verisi yüklenirken hata oluştu: " + ex.Message); }
    }
    private void OnYeni() { _model = new(); _operation = "add"; }
    private void OnDuzenle(Uye secilenUye) { _model = secilenUye; _operation = "update"; }
    private async Task OnKaydet() {
        try {
            await KutuphaneServisi.UyeKaydetAsync(_model, _operation);
            await JSRuntime.InvokeVoidAsync("alert", _operation == "add" ? "Üye başarıyla eklendi!" : "Üye güncellendi!");
            await VerileriGetir();
        } catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", "Kayıt sırasında hata oluştu: " + ex.Message); }
    }
    private async Task OnSil(int id) {
        try {
            bool onay = await JSRuntime.InvokeAsync<bool>("confirm", "Bu üyeyi pasif hale getirmek istediğinize emin misiniz?");
            if (onay) {
                await KutuphaneServisi.UyeSilAsync(id);
                await JSRuntime.InvokeVoidAsync("alert", "Üye pasif hale getirildi.");
                await VerileriGetir();
            }
        } catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", "Silme sırasında hata oluştu: " + ex.Message); }
    }
}