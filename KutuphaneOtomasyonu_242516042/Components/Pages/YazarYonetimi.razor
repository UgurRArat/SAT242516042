@page "/yazarlar"
@using KutuphaneOtomasyonu_242516042.Models
@using KutuphaneOtomasyonu_242516042.Data
@inject KutuphaneServisi KutuphaneServisi
@inject IJSRuntime JSRuntime
<PageTitle>Yazar Yönetimi</PageTitle>

<h3>Yazar Yönetimi</h3>

@if (!string.IsNullOrEmpty(_hataMesaji))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Hata:</strong> @_hataMesaji
        <button type="button" class="btn-close" @onclick="HataKapat" aria-label="Close"></button>
    </div>
}

<EditForm Model="_model" OnValidSubmit="OnKaydet" FormName="YazarFormu">
    <DataAnnotationsValidator />
    <div class="card shadow mb-4">
        <div class="card-header">@(_model.Id == 0 ? "Yeni Yazar Ekle" : "Yazar Düzenle")</div>
        <div class="card-body">
            <input type="hidden" @bind-value="_model.Id" />
            <div class="row">
                <div class="col-md-6">
                    <label>Ad</label>
                    <InputText class="form-control" @bind-Value="_model.Ad" />
                </div>
                <div class="col-md-6">
                    <label>Soyad</label>
                    <InputText class="form-control" @bind-Value="_model.Soyad" />
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <button type="button" class="btn btn-secondary" @onclick="OnYeni">Yeni</button>
        </div>
    </div>
</EditForm>

@if (_yazarListesi == null)
{
    <p><em>Yükleniyor...</em></p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark"><tr><th>Ad Soyad</th><th>Durum</th><th>İşlemler</th></tr></thead>
        <tbody>
            @foreach (var yazar in _yazarListesi)
            {
                <tr>
                    <td>@yazar.TamAd</td>
                    <td>@yazar.Durum</td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="() => OnDuzenle(yazar)">Düzenle</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => OnSil(yazar.Id)">Sil</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Yazar>? _yazarListesi;
    private Yazar _model = new();
    private string _operation = "add";
    private string? _hataMesaji;

    protected override async Task OnInitializedAsync() { await VerileriGetir(); }

    private async Task VerileriGetir()
    {
        try { _yazarListesi = await KutuphaneServisi.YazarListeleAsync(); }
        catch (Exception ex) { _hataMesaji = ex.Message; }
    }

    private void HataKapat() { _hataMesaji = null; }

    private void OnYeni() { _model = new(); _operation = "add"; _hataMesaji = null; }

    private void OnDuzenle(Yazar yazar) { _model = yazar; _operation = "update"; _hataMesaji = null; }

    private async Task OnKaydet()
    {
        try
        {
            // Yazar kaydetme için özel prosedürümüzü servise eklememiş olabiliriz,
            // ama genelde CRUD işlemleri benzerdir.
            // NOT: KutuphaneServisi içinde 'YazarKaydetAsync' yoksa aşağıya ekleyeceğim kodu servise eklemelisin.
            await KutuphaneServisi.YazarKaydetAsync(_model, _operation);
            await VerileriGetir();
            OnYeni();
        }
        catch (Exception ex) { _hataMesaji = "Kayıt hatası: " + ex.Message; }
    }

    private async Task OnSil(int id)
    {
        try
        {
            bool onay = await JSRuntime.InvokeAsync<bool>("confirm", "Silmek istediğinize emin misiniz?");
            if (onay)
            {
                await KutuphaneServisi.YazarSilAsync(id);
                await VerileriGetir();
            }
        }
        catch (Exception ex) { _hataMesaji = "Silme hatası: " + ex.Message; }
    }
}