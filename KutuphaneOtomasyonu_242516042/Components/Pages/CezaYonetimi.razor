@page "/cezalar"
@using KutuphaneOtomasyonu_242516042.Models
@using KutuphaneOtomasyonu_242516042.Data
@inject KutuphaneServisi KutuphaneServisi
@inject IJSRuntime JSRuntime
<PageTitle>Ceza Yönetimi</PageTitle>

<h3>Ödenmemiş Gecikme Cezaları</h3>

@if (!string.IsNullOrEmpty(_hataMesaji))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Hata Oluştu:</strong> @_hataMesaji
        <button type="button" class="btn-close" @onclick="HataKapat" aria-label="Close"></button>
    </div>
}

@if (_cezaListesi == null)
{
    <p><em>Yükleniyor...</em></p>
}
else if (!_cezaListesi.Any())
{
    <div class="alert alert-success">Şu an ödenmemiş ceza bulunmamaktadır.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Üye Adı</th>
                <th>Kitap Adı</th>
                <th>Açıklama</th>
                <th>Tutar (TL)</th>
                <th>Ceza Tarihi</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ceza in _cezaListesi)
            {
                <tr>
                    <td>@ceza.UyeTamAdi</td>
                    <td>@ceza.KitapAdi</td>
                    <td>@ceza.Aciklama</td>
                    <td>@ceza.CezaTutari.ToString("0.00") TL</td>
                    <td>@ceza.CezaBitisTarihi.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="() => HandleCezaOde(ceza.Id)">Ödendi Olarak İşaretle</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Ceza>? _cezaListesi;
    private string? _hataMesaji;

    protected override async Task OnInitializedAsync()
    {
        await VerileriGetir();
    }

    private async Task VerileriGetir()
    {
        _hataMesaji = null;
        try
        {
            _cezaListesi = await KutuphaneServisi.GetOdenmemisCezalarAsync();
        }
        catch (Exception ex)
        {
            // Alert yerine değişkene yazıyoruz
            _hataMesaji = "Cezalar yüklenirken hata oluştu: " + ex.Message;
        }
    }

    private void HataKapat()
    {
        _hataMesaji = null;
    }

    private async Task HandleCezaOde(int cezaId)
    {
        try
        {
            bool onay = await JSRuntime.InvokeAsync<bool>("confirm", "Bu ceza ödendi olarak işaretlenecek. Emin misiniz?");
            if (onay)
            {
                await KutuphaneServisi.CezaOdeAsync(cezaId);
                // await JSRuntime.InvokeVoidAsync("alert", "Ceza ödendi."); // İstersen açabilirsin
                await VerileriGetir();
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "İşlem sırasında hata: " + ex.Message;
        }
    }
}